# =============================================================================
# 爆款文案改写 —— 项目级非敏感配置示例
# =============================================================================
# 真实凭证（FEISHU_APP_ID/SECRET、DEEPSEEK_API_KEY）放在 user 目录：
#   Windows: %APPDATA%\baokuan-rewrite\.env
# 项目级 .env 只放下面这些非敏感配置。
# =============================================================================

# DeepSeek 模型与接口
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# CLI 路径(默认就是 claude / codex,放在 PATH 即可;如需指定绝对路径请改这里)
CLAUDE_CMD=claude
CODEX_CMD=codex

# 会话保持时长(秒)。默认 1800 = 30 分钟
SESSION_TIMEOUT=1800

# 引擎选择方式: card / text
# 默认 card，保留飞书交互卡片；text 只作为调试兜底开关
ENGINE_PICKER_MODE=card
