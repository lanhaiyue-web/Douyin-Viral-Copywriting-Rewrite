# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/

# =============================================================================
# 凭证 / 环境
# 真实凭证（FEISHU_APP_ID/SECRET、DEEPSEEK_API_KEY）放在 %APPDATA%\baokuan-rewrite\.env
# 项目内的 .env 也不进 git，以防万一
# =============================================================================
.env
.env.local
*.env.local

# =============================================================================
# 抖音创作者中心持久化登录态 —— 绝对不能上传
# 每个人本地扫码后自己生成
# =============================================================================
.auth/

# =============================================================================
# 运行时缓存 / 调试产物
# =============================================================================
.cache/
.cheat-cache/

# =============================================================================
# 个人后台数据（运行时由 抓后台.bat 自动生成）
# =============================================================================
context/my-history-backend.md
context/comments/

# =============================================================================
# 个人口吻档案 + 对标账号数据
# 提供 .template.md 版本作为模板；本人填的版本不进 git
# =============================================================================
context/my-voice-profile.md
context/benchmarks/*.md
!context/benchmarks/*.template.md

# =============================================================================
# 个人草稿 / 已写文案
# scripts/_template.md 例外（作为模板）
# =============================================================================
scripts/*.md
!scripts/_template.md

# =============================================================================
# 飞书任务记录 / 日志
# =============================================================================
tasks/inbox.md
tasks/history.md
logs/
*.log
.target.json
target.json

# =============================================================================
# docs/ 内部状态文档（项目维护者本地记忆，不公开）
# =============================================================================
docs/internal/

# =============================================================================
# 操作系统 / IDE
# =============================================================================
.DS_Store
Thumbs.db
.vscode/
.idea/

# =============================================================================
# 临时
# =============================================================================
_*.py
_*.json
*.tmp
